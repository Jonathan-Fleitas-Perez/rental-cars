// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Car {
  id           String   @id @default(uuid())
  userId       String
  name         String   @db.Text
  cv           String   @db.Text
  transmission String   @db.Text
  people       String   @db.Text
  photo        String   @db.Text // Miniatura principal
  priceDay     String   @db.Text
  engine       String   @db.Text
  type         String   @db.Text
  isPublish    Boolean  @default(false)
  isSold       Boolean  @default(false) // Para módulo de ventas

  images  CarImage[]
  reviews Review[]
  orders  Order[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
}

model CarImage {
  id    String @id @default(uuid())
  url   String @db.Text
  carId String
  car   Car    @relation(fields: [carId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([carId])
}

model Review {
  id        String   @id @default(uuid())
  userId    String
  userName  String   @db.Text
  avatarUrl String?  @db.Text
  rating    Int
  comment   String   @db.Text
  carId     String
  car       Car      @relation(fields: [carId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([carId])
  @@index([userId])
}

model Order {
  id           String   @id @default(uuid())
  carId        String   @db.Text
  carName      String   @db.Text
  userId       String   @db.Text
  orderDate    DateTime @default(now())
  orderEndDate DateTime @default(now())
  status       String   @db.Text // "pending", "paid", "confirmed", "refunded"
  totalAmount  String   @db.Text

  car Car @relation(fields: [carId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([carId])
  @@index([userId])
}

